    <mxCell id="s4_std_txt" value="• Data Quality (5 check types: row_count, not_null, not_negative, allowed_values, regex)&#xa;  severity: error / warning&#xa;• Standardization (trim, upper, cast, add_column)&#xa;• Data Type Conversion &amp; Validation&#xa;• BatchID tracking (ADF pipeline_run_id)&#xa;• Deduplication via SHA-256 transaction hash&#xa;• Column Masking (Unity Catalog — PII protection)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#BDD7EE;" vertex="1" parent="1">
