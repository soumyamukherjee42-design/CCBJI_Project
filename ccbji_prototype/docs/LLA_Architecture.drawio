    <mxCell id="g_schema" value="&lt;b&gt;Gold Schema (gold.*)&lt;/b&gt;&lt;br/&gt;dim_date (full overwrite)&lt;br/&gt;dim_customer — SCD2, partitioned&lt;br/&gt;dim_product — SCD2, partitioned&lt;br/&gt;fact_sales — MERGE on transaction_hash, partitioned by fact_batch_id&lt;br/&gt;late_arriving_dimension_bridge — PENDING / RESOLVED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
