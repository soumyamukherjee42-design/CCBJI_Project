    <!-- ═══ SECURITY (right column) ══════════════════════════════════════════ -->
    <mxCell id="z_sec" value="Cross-Cutting Security &amp; Governance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1700" y="200" width="600" height="1070" as="geometry" />
    </mxCell>

    <mxCell id="sec1" value="&lt;b&gt;ADLS Customer-Managed Key (CMK)&lt;/b&gt;&lt;br/&gt;Azure Key Vault holds encryption key&lt;br/&gt;All data at rest encrypted (ADLS Gen2)&lt;br/&gt;Key rotation policy + access policy configured&lt;br/&gt;Key Vault soft-delete + purge protection on" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="235" width="570" height="80" as="geometry" />
    </mxCell>

    <mxCell id="sec2" value="&lt;b&gt;Unity Catalog Column Masking&lt;/b&gt;&lt;br/&gt;ALTER TABLE … ALTER COLUMN … SET MASK&lt;br/&gt;mask_function: Python/SQL UDF per PII column&lt;br/&gt;exempt_roles: [data_engineer, analyst] see plaintext&lt;br/&gt;Non-exempt roles receive NULL for masked columns&lt;br/&gt;Applied at Bronze AND Silver AND Gold layers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="330" width="570" height="90" as="geometry" />
    </mxCell>

    <mxCell id="sec3" value="&lt;b&gt;Mask Function Examples&lt;/b&gt;&lt;br/&gt;pii_mask_customer_name(name, ctx)&lt;br/&gt;pii_mask_email(email, ctx)&lt;br/&gt;pii_mask_phone(phone, ctx)&lt;br/&gt;→ Returns original for exempt roles, else NULL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="435" width="570" height="80" as="geometry" />
    </mxCell>

    <mxCell id="sec4" value="&lt;b&gt;Secrets Management&lt;/b&gt;&lt;br/&gt;Databricks Secret Scope backed by Azure Key Vault&lt;br/&gt;dbutils.secrets.get(scope, key) — no secrets in code&lt;br/&gt;ADLS SAS / service principal credentials via secrets&lt;br/&gt;No credentials in YAML config files" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="530" width="570" height="80" as="geometry" />
    </mxCell>

    <mxCell id="sec5" value="&lt;b&gt;Unity Catalog RBAC / ACLs&lt;/b&gt;&lt;br/&gt;Catalog → Schema → Table level GRANTs&lt;br/&gt;Row-level + column-level security enforced&lt;br/&gt;Data steward approval required for PII access&lt;br/&gt;Audit trail for all access events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="625" width="570" height="80" as="geometry" />
    </mxCell>

    <mxCell id="sec6" value="&lt;b&gt;Network Controls&lt;/b&gt;&lt;br/&gt;Azure Private Endpoints for ADLS + Key Vault&lt;br/&gt;Databricks Managed VNet — no public inbound&lt;br/&gt;NSG rules restrict egress&lt;br/&gt;ADF Managed Integration Runtime in VNet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="720" width="570" height="80" as="geometry" />
    </mxCell>

    <mxCell id="sec7" value="&lt;b&gt;CI/CD Security Gates&lt;/b&gt;&lt;br/&gt;validate_yamls.py — blocks malformed DQ / security YAML&lt;br/&gt;87 pytest tests — prevents regression in DQ / security logic&lt;br/&gt;GitHub Actions: dev auto-deploy, prod manual approval gate&lt;br/&gt;Branch protection rules on main" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="815" width="570" height="80" as="geometry" />
    </mxCell>

    <mxCell id="sec8" value="&lt;b&gt;Immutable Audit Trail&lt;/b&gt;&lt;br/&gt;audit.pipeline_run_log — all pipeline executions&lt;br/&gt;audit.dq_check_log — every DQ check result&lt;br/&gt;audit.alert_log — error-severity failures&lt;br/&gt;silver.*_error — rejected rows (never deleted)&lt;br/&gt;Delta tables; append-only; no DELETE operations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1715" y="910" width="570" height="90" as="geometry" />
    </mxCell>

