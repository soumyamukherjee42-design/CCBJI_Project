    </mxCell>

    <!-- SD 2 -->
    <mxCell id="s2" value="&lt;b&gt;2. Write Bronze Delta  (overwrite)&lt;/b&gt;&lt;br/&gt;spark.write.format('delta').mode('overwrite')&lt;br/&gt;Adds batch_id + processed_date (UTC)&lt;br/&gt;Partitioned by batch_id; each run replaces prior snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="40" y="315" width="540" height="70" as="geometry" />
