    <!-- ═══ TF ENGINE (middle column) ════════════════════════════════════════ -->
    <mxCell id="z_tf2" value="TF_Gold_Load_Engine  —  Silver → Gold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555555;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="620" y="200" width="1060" height="1070" as="geometry" />
    </mxCell>

    <!-- TF 1 Route -->
    <mxCell id="t1" value="&lt;b&gt;1. Route by object_type&lt;/b&gt;&lt;br/&gt;Read YAML cfg → detect object_type → dispatch to sub-engine&lt;br/&gt;Reads token-substituted table names / paths from cfg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="640" y="235" width="1020" height="60" as="geometry" />
    </mxCell>

    <!-- TF 2a Dim Date -->
    <mxCell id="t2a" value="&lt;b&gt;2a. Dim Date Engine (full overwrite)&lt;/b&gt;&lt;br/&gt;Generates date_key (yyyyMMdd INT), calendar_date, year,&lt;br/&gt;quarter, month, month_name, week_of_year,&lt;br/&gt;day_of_week, day_name, is_weekend&lt;br/&gt;date_range from source config; mode='overwrite'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="640" y="315" width="490" height="85" as="geometry" />
    </mxCell>

    <!-- TF 2b SCD2 -->
    <mxCell id="t2b" value="&lt;b&gt;2b. SCD Type 2 Engine&lt;/b&gt;&lt;br/&gt;SHA-256(tracked cols) → attribute_hash&lt;br/&gt;Compare hash to current dim row (is_current=true)&lt;br/&gt;New record: INSERT with SK, effective_from=today, effective_to=9999-12-31&lt;br/&gt;Changed: expire current (effective_to=today-1, is_current=false) + INSERT new&lt;br/&gt;Sentinel: surrogate_key=-1, natural_key=UNKNOWN, eff 1900–9999" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1150" y="315" width="510" height="105" as="geometry" />
    </mxCell>

    <!-- TF 3a Fact -->
    <mxCell id="t3a" value="&lt;b&gt;3a. Fact Engine — FactSales&lt;/b&gt;&lt;br/&gt;SHA-256(source_system ‖ sales_id ‖ order_date) → transaction_hash&lt;br/&gt;Temporal FK join: dim SK valid at transaction_date (effective_from ≤ date ≤ effective_to)&lt;br/&gt;Late-arriving: customer_key / product_key = -1 if no dim row found&lt;br/&gt;Creates bridge entry (PENDING) for unresolved FKs&lt;br/&gt;MERGE ON transaction_hash → idempotent upsert; partitioned by fact_batch_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="640" y="420" width="490" height="105" as="geometry" />
    </mxCell>

    <!-- TF 3b Resolution -->
    <mxCell id="t3b" value="&lt;b&gt;3b. Resolution Engine&lt;/b&gt;&lt;br/&gt;Reads late_arriving_dimension_bridge WHERE status='PENDING'&lt;br/&gt;Looks up dim SK for natural_key valid at transaction_date&lt;br/&gt;If found: MERGE fact table updating SK column; mark bridge RESOLVED&lt;br/&gt;resolved_surrogate_key + resolved_timestamp populated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1150" y="435" width="510" height="90" as="geometry" />
    </mxCell>

    <!-- Late arriving bridge -->
    <mxCell id="t_bridge" value="&lt;b&gt;gold.late_arriving_dimension_bridge&lt;/b&gt;&lt;br/&gt;resolution_hash = SHA-256(transaction_hash ‖ dim_name ‖ natural_key)&lt;br/&gt;transaction_hash (FK → fact_sales)&lt;br/&gt;dimension_name / natural_key / transaction_date&lt;br/&gt;fact_key_column / fact_table_name&lt;br/&gt;PENDING → fact SK=-1 | RESOLVED → FK backfilled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1150" y="540" width="510" height="100" as="geometry" />
    </mxCell>

    <!-- TF 4 Column Mask Gold -->
    <mxCell id="t4" value="&lt;b&gt;4. Column Mask — Gold&lt;/b&gt;&lt;br/&gt;_apply_column_masks(gold_table)&lt;br/&gt;ALTER TABLE … ALTER COLUMN … SET MASK (Unity Catalog); graceful skip in CE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="640" y="660" width="1020" height="55" as="geometry" />
    </mxCell>

    <!-- TF 5 DQ box -->
    <mxCell id="t5bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="640" y="730" width="1020" height="230" as="geometry" />
    </mxCell>
    <mxCell id="t5h" value="&lt;b&gt;5. Gold DQ Checks — 7 check types (post-load validation against written Gold table)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="652" y="735" width="790" height="20" as="geometry" />
    </mxCell>
    <mxCell id="t5_rcm" value="row_count_min — table rows ≥ min" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="652" y="760" width="320" height="28" as="geometry" /></mxCell>
    <mxCell id="t5_nn"  value="not_null — column must not be NULL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="984" y="760" width="320" height="28" as="geometry" /></mxCell>
    <mxCell id="t5_ng"  value="not_negative — numeric ≥ 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="652" y="798" width="320" height="28" as="geometry" /></mxCell>
    <mxCell id="t5_zc"  value="zero_check — warn if any value = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="984" y="798" width="320" height="28" as="geometry" /></mxCell>
    <mxCell id="t5_av"  value="allowed_values — value in permitted set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="652" y="836" width="320" height="28" as="geometry" /></mxCell>
    <mxCell id="t5_dk"  value="duplicate_key — composite key must be unique" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="984" y="836" width="320" height="28" as="geometry" /></mxCell>
    <mxCell id="t5_ri"  value="referential_integrity — FK exists in dim table (excluding unknown_key = -1 sentinel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="652" y="874" width="652" height="28" as="geometry" /></mxCell>
    <mxCell id="t5_sv"  value="severity=error → DQ_FAILED flag + audit log  |  severity=warning → log only, load still succeeds" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="652" y="912" width="996" height="20" as="geometry" /></mxCell>
    <mxCell id="t5_note" value="DQ checks run post-load (validation, not filtering) — results written to audit.dq_check_log" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="652" y="934" width="996" height="16" as="geometry" /></mxCell>

    <!-- TF 6 Audit -->
    <mxCell id="t6" value="&lt;b&gt;6. Audit Write&lt;/b&gt;&lt;br/&gt;_audit_log() → audit.pipeline_run_log (rows_written, duration, COMPLETED/FAILED)&lt;br/&gt;_dq_log() → audit.dq_check_log (per-check: PASSED/FAILED, rows_checked, rows_failed)&lt;br/&gt;_alert_log() → audit.alert_log when error-severity DQ check fails" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555555;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="640" y="975" width="1020" height="75" as="geometry" />
