    <mxCell id="s6a" value="&lt;b&gt;6a. Silver Write — Good Rows&lt;/b&gt;&lt;br/&gt;mode='append'; partitioned by batch_id&lt;br/&gt;Full history retained across all batches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
