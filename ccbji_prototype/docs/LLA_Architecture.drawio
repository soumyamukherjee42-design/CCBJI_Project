    <mxCell id="s5_av"  value="allowed_values — value in permitted set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="1"><mxGeometry x="312" y="648" width="248" height="28" as="geometry" /></mxCell>
