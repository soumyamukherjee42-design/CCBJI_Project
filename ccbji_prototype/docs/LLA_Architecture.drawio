    <!-- SD 1 -->
    <mxCell id="s1" value="&lt;b&gt;1. ADF Trigger / Read ADLS CSV&lt;/b&gt;&lt;br/&gt;Storage Event Trigger on inbound/{source}/&lt;br/&gt;pipeline_run_id passed as batch_id&lt;br/&gt;spark.read.csv (schema-on-read)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
