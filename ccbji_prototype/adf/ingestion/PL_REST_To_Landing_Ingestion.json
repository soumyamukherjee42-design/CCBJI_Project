{
  "name": "PL_REST_To_Landing_Ingestion",
  "properties": {
    "description": "Generic pipeline: calls a REST API with pagination, writes the response as CSV to the ADLS landing zone.",
    "parameters": {
      "base_url": {
        "type": "string"
      },
      "endpoint": {
        "type": "string"
      },
      "destination_folder": {
        "type": "string"
      },
      "batch_id": {
        "type": "string"
      },
      "page_size": {
        "type": "int",
        "defaultValue": 500
      }
    },
    "variables": {
      "current_page": {
        "type": "Integer",
        "defaultValue": 1
      },
      "has_more": {
        "type": "Boolean",
        "defaultValue": true
      }
    },
    "activities": [
      {
        "name": "Until_No_More_Pages",
        "type": "Until",
        "dependsOn": [],
        "typeProperties": {
          "expression": {
            "value": "@not(variables('has_more'))",
            "type": "Expression"
          },
          "timeout": "02:00:00",
          "activities": [
            {
              "name": "Call_REST_API",
              "type": "Copy",
              "dependsOn": [],
              "policy": {
                "timeout": "00:30:00",
                "retry": 3,
                "retryIntervalInSeconds": 30
              },
              "typeProperties": {
                "source": {
                  "type": "RestSource",
                  "httpRequestTimeout": "00:05:00",
                  "requestInterval": "00:00:01",
                  "requestMethod": "GET",
                  "additionalHeaders": {
                    "Accept": "application/json"
                  },
                  "paginationRules": {
                    "QueryParameters.page": "RANGE:1:100"
                  }
                },
                "sink": {
                  "type": "DelimitedTextSink",
                  "storeSettings": {
                    "type": "AzureBlobFSWriteSettings"
                  },
                  "formatSettings": {
                    "type": "DelimitedTextWriteSettings",
                    "quoteAllText": true,
                    "fileExtension": ".csv"
                  }
                },
                "enableStaging": false
              },
              "inputs": [
                {
                  "referenceName": "ds_rest_api_source",
                  "type": "DatasetReference",
                  "parameters": {
                    "base_url": {
                      "value": "@pipeline().parameters.base_url",
                      "type": "Expression"
                    },
                    "endpoint": {
                      "value": "@pipeline().parameters.endpoint",
                      "type": "Expression"
                    }
                  }
                }
              ],
              "outputs": [
                {
                  "referenceName": "ds_adls_csv_landing",
                  "type": "DatasetReference",
                  "parameters": {
                    "folder_path": {
                      "value": "@concat('inbound/', pipeline().parameters.destination_folder, '/')",
                      "type": "Expression"
                    },
                    "file_name": {
                      "value": "@concat(pipeline().parameters.destination_folder, '_', pipeline().parameters.batch_id, '_p', variables('current_page'), '.csv')",
                      "type": "Expression"
                    }
                  }
                }
              ]
            },
            {
              "name": "Set_Has_More_False",
              "type": "SetVariable",
              "dependsOn": [
                {
                  "activity": "Call_REST_API",
                  "dependencyConditions": ["Succeeded"]
                }
              ],
              "typeProperties": {
                "variableName": "has_more",
                "value": {
                  "value": "@greater(activity('Call_REST_API').output.rowsCopied, 0)",
                  "type": "Expression"
                }
              }
            }
          ]
        }
      }
    ]
  }
}
